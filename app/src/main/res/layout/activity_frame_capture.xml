<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ImageView
                android:id="@+id/ivFramePreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter" />

            <ProgressBar
                android:id="@+id/frameCaptureProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvFrameTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:paddingTop="4dp" />

        <SeekBar
            android:id="@+id/seekBarFrame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <TextView
            android:id="@+id/btnCaptureFrame"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="@string/frame_capture_capture_btn"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/bg_ios_circle_blue" />

        <TextView
            android:id="@+id/tvFrameCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:text="@string/frame_capture_none_yet" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:id="@+id/capturedFramesStrip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />
        </HorizontalScrollView>

    </LinearLayout>

    <ImageButton
        android:id="@+id/btnFrameCaptureClose"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|start"
        android:layout_margin="14dp"
        android:padding="8dp"
        android:background="@drawable/bg_ios_circle_blue"
        android:src="@drawable/ic_close_white"
        android:elevation="4dp"
        android:contentDescription="@string/frame_capture_close_desc" />

    <ImageButton
        android:id="@+id/btnFrameCaptureSave"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_margin="14dp"
        android:padding="8dp"
        android:background="@drawable/bg_ios_circle_blue"
        android:src="@drawable/ic_check_white"
        android:elevation="4dp"
        android:contentDescription="@string/frame_capture_save_btn" />

</FrameLayout>
